{
  "name": "poetheme",
  "version": "1.9.0",
  "private": true,
  "description": "Build tooling for the PoeTheme WordPress theme (Tailwind CSS build and i18n helpers).",
  "license": "GPL-2.0-or-later",
  "scripts": {
    "build:css": "tailwindcss -i ./assets/css/tailwind-src.css -o ./assets/css/tailwind.min.css --minify",
    "watch:css": "tailwindcss -i ./assets/css/tailwind-src.css -o ./assets/css/tailwind.min.css --watch",
    "build:mo": "node tools/compile-mo.js",
    "build": "npm run build:css && npm run build:mo"
  },
  "devDependencies": {
    "gettext-parser": "^8.0.0",
    "tailwindcss": "^3.4.0"
  }
}
